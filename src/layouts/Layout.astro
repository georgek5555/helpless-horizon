---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  publishedAt?: string;
}

const {
  title,
  description,
  ogImage,
  canonicalUrl,
  type = 'website',
  publishedAt,
} = Astro.props;

const siteName = 'テストブログYES';
const siteUrl = import.meta.env.SITE_URL ?? (Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.134.network');
const fullTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const canonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;
const metaDescription = description ?? `${siteName} の記事をお読みいただけます。`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="ja_JP" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {type === 'article' && publishedAt && (
      <meta property="article:published_time" content={publishedAt} />
    )}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Noto Serif JP -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="site-name">{siteName}</a>
        <div class="header-rule"></div>
      </div>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :global(html) {
    font-family: 'Noto Serif JP', 'Times New Roman', serif;
    background: #0a0a0a;
    color: #ffffff;
    -webkit-font-smoothing: antialiased;
  }

  :global(body) {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 1.5rem 2rem 3rem;
    pointer-events: none;
    background: linear-gradient(to bottom, #0a0a0a 40%, transparent);
  }

  .header-inner {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .site-name {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #FFCC22;
    text-decoration: none;
    font-weight: 500;
    white-space: nowrap;
    pointer-events: all;
    transition: opacity 0.15s;
  }
  .site-name:hover { opacity: 0.65; }

  .header-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, rgba(255, 204, 34, 0.35), transparent 70%);
    transform: skewX(-25deg);
    transform-origin: left center;
  }

  main {
    flex: 1;
  }

</style>
