---
import Layout from '../layouts/Layout.astro';

const res = await fetch(
  "http://133.117.77.80:8055/items/posts?fields=*,site.*,eyecatch.filename_disk&filter[status][_eq]=published&sort=-date_created",
  { cache: "no-store" }
);
const json = await res.json();
const posts = Array.isArray(json?.data) ? json.data : [];

function formatDate(dateStr: string | undefined) {
  if (!dateStr) return null;
  return new Date(dateStr).toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title="テストブログYES" description="最新の記事をお届けします。">
  <div class="page">
    <div class="posts">
      {posts.map((post, i) => (
        <a href={`/${post.slug}`} class="post" data-index={i}>
          <div class="post-inner">
            <!-- Image -->
            <div class="post-image-wrap">
              {post.eyecatch?.filename_disk ? (
                <img
                  src={`https://img.134.network/${post.eyecatch.filename_disk}`}
                  alt={post.title}
                  loading="lazy"
                  class="post-img"
                />
              ) : (
                <div class="post-img-placeholder">No Image</div>
              )}
              <div class="post-img-overlay"></div>
            </div>

            <!-- Content -->
            <div class="post-content">
              <h2 class="post-title">{post.title}</h2>
              <div class="post-meta">
                {post.date_created && <span>{formatDate(post.date_created)}</span>}
              </div>
              <span class="post-arrow">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .page {
    max-width: 860px;
    margin: 0 auto;
    padding: 5.5rem 2rem 8rem;
  }

  /* Posts list */
  .posts {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post {
    display: block;
    text-decoration: none;
    opacity: 0;
    transform: translateY(32px);
    animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .post[data-index="0"] { animation-delay: 0.05s; }
  .post[data-index="1"] { animation-delay: 0.15s; }
  .post[data-index="2"] { animation-delay: 0.25s; }
  .post[data-index="3"] { animation-delay: 0.35s; }
  .post[data-index="4"] { animation-delay: 0.45s; }
  .post[data-index="5"] { animation-delay: 0.55s; }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .post-inner {
    position: relative;
    padding: 3rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post:last-child .post-inner {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .post:hover .post-inner {
    transform: translateX(6px);
  }

  /* Image */
  .post-image-wrap {
    width: 100%;
    aspect-ratio: 16 / 7;
    overflow: hidden;
    position: relative;
    margin-bottom: 1.75rem;
  }


  .post-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.75);
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1),
                filter 0.4s ease;
  }

  .post:hover .post-img {
    transform: scale(1.03);
    filter: brightness(0.9);
  }

  .post-img-overlay {
    position: absolute;
    inset: -1px;
    background: #0a0a0a;
    clip-path: polygon(100% 100%, 100% 100%, 100% 100%);
    transition: clip-path 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: clip-path;
    pointer-events: none;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 1.25rem 1.5rem;
  }

  .post:hover .post-img-overlay {
    clip-path: polygon(-1% 101%, 101% 45%, 101% 101%);
  }

  .post-img-placeholder {
    width: 100%;
    height: 100%;
    background: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.1);
  }

  /* Content */
  .post-content {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    align-items: start;
    gap: 0 1.5rem;
  }

  .post-title {
    grid-column: 1;
    grid-row: 1;
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    font-weight: 700;
    line-height: 1.5;
    color: #ffffff;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .post:hover .post-title {
    color: #FFCC22;
  }

  .post-meta {
    grid-column: 1;
    grid-row: 2;
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.08em;
  }

  .post-arrow {
    grid-column: 2;
    grid-row: 1 / 3;
    font-size: 1.1rem;
    color: #FFCC22;
    opacity: 0;
    align-self: center;
    transform: translateX(-8px);
    transition: opacity 0.25s, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post:hover .post-arrow {
    opacity: 0.8;
    transform: translateX(0);
  }
</style>
