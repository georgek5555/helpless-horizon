---
import Layout from '../layouts/Layout.astro';
import { getPosts, getTitle, getFeaturedImage, getCategory, getPostPath } from '../lib/wordpress';

let posts: any[] = [];
try {
  posts = await getPosts(20);
} catch (e) {
  posts = [];
}

const hero = posts[0] ?? null;
const gridPosts = posts.slice(1);

const WP_API = import.meta.env.WP_API_URL ?? 'https://solocial.net/wp-json/wp/v2';

function formatDate(dateStr: string | undefined) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.');
}
---

<Layout title="Solocial" description="SNSとソーシャルメディアを深く読む。">

  <div class="page">

    <!-- HERO -->
    {hero && (
      <section class="hero-section">
        <div class="wrap">
          <a href={`/${getPostPath(hero)}`} class="hero-tile">
            <div class="hero-color-block">
              <span class="tile-kicker">{getCategory(hero).toUpperCase()}</span>
              <h1 class="hero-title">{getTitle(hero)}</h1>
              <div class="hero-foot">
                {hero.date && <span class="mono-label">{formatDate(hero.date)}</span>}
                <span class="hero-cta">READ →</span>
              </div>
            </div>
            <div class="hero-image-panel">
              {getFeaturedImage(hero) ? (
                <img src={getFeaturedImage(hero)!} alt={getTitle(hero)} class="hero-img" />
              ) : (
                <div class="hero-img-placeholder"></div>
              )}
            </div>
          </a>
        </div>
      </section>
    )}

    <!-- LATEST GRID -->
    <section class="stream-section">
      <div class="wrap">
        <div class="stream-header">
          <span class="stream-label">LATEST</span>
          <div class="stream-rule"></div>
        </div>

        <div class="post-grid" id="post-grid" data-api={WP_API}>
          {gridPosts.map((post, i) => (
            <a href={`/${getPostPath(post)}`} class="post-card" style={`animation-delay:${i * 0.04}s`}>
              <div class="post-card-img-wrap">
                {getFeaturedImage(post) ? (
                  <img src={getFeaturedImage(post)!} alt={getTitle(post)} loading="lazy" class="post-card-img" />
                ) : (
                  <div class="post-card-img-empty"></div>
                )}
              </div>
              <div class="post-card-body">
                <span class="post-card-kicker">{getCategory(post).toUpperCase()}</span>
                <h2 class="post-card-title">{getTitle(post)}</h2>
                <span class="post-card-date">{formatDate(post.date)}</span>
              </div>
            </a>
          ))}
        </div>

        <div id="load-sentinel" class="load-sentinel"></div>
        <div id="load-status" class="load-status" hidden>
          <span class="load-dots"><span></span><span></span><span></span></span>
        </div>
      </div>
    </section>

  </div>

</Layout>

<script>
  const grid = document.getElementById('post-grid') as HTMLElement;
  const sentinel = document.getElementById('load-sentinel') as HTMLElement;
  const status = document.getElementById('load-status') as HTMLElement;
  const WP_API = grid?.dataset.api ?? 'https://solocial.net/wp-json/wp/v2';

  let page = 2;
  let loading = false;
  let finished = false;

  function formatDate(dateStr: string): string {
    const d = new Date(dateStr);
    return d.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.');
  }

  function buildCard(post: any): HTMLElement {
    const img = post._embedded?.['wp:featuredmedia']?.[0]?.source_url ?? null;
    const category = post._embedded?.['wp:term']?.[0]?.[0]?.name ?? 'SNS';
    const title = post.title?.rendered ?? '';
    const date = post.date ? formatDate(post.date) : '';
    let linkPath = post.slug;
    try { linkPath = new URL(post.link).pathname.replace(/^\/|\/$/g, ''); } catch {}

    const a = document.createElement('a');
    a.href = `/${linkPath}`;
    a.className = 'post-card';
    a.innerHTML = `
      <div class="post-card-img-wrap">
        ${img
          ? `<img src="${img}" alt="" loading="lazy" class="post-card-img">`
          : `<div class="post-card-img-empty"></div>`}
      </div>
      <div class="post-card-body">
        <span class="post-card-kicker">${category.toUpperCase()}</span>
        <h2 class="post-card-title">${title}</h2>
        <span class="post-card-date">${date}</span>
      </div>
    `;
    return a;
  }

  async function loadMore() {
    if (loading || finished || !grid) return;
    loading = true;
    status.hidden = false;

    try {
      const res = await fetch(
        `${WP_API}/posts?per_page=20&page=${page}&orderby=date&order=desc&status=publish&_embed=true`
      );
      if (!res.ok) { finished = true; return; }
      const posts: any[] = await res.json();
      if (posts.length === 0) { finished = true; return; }

      posts.forEach(post => grid.appendChild(buildCard(post)));
      page++;
      if (posts.length < 20) finished = true;
    } catch {
      finished = true;
    } finally {
      loading = false;
      status.hidden = true;
    }
  }

  const observer = new IntersectionObserver(
    entries => { if (entries[0].isIntersecting) loadMore(); },
    { rootMargin: '300px' }
  );
  if (sentinel) observer.observe(sentinel);
</script>

<style>
  .page { padding-bottom: 5rem; }

  .wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── HERO ── */
  .hero-section {
    padding: 1.5rem 0;
  }

  .hero-tile {
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    border: 1px solid var(--color-border);
    text-decoration: none;
    min-height: 340px;
    transition: box-shadow 0.2s;
  }

  .hero-tile:hover {
    box-shadow: 0 0 0 2px var(--color-blue);
  }

  .hero-color-block {
    background: var(--color-tile-blue);
    padding: 2.5rem 2.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .tile-kicker {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.7);
    display: block;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: 0.01em;
    color: #ffffff;
    text-transform: uppercase;
  }

  .hero-foot {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 0.25rem;
  }

  .mono-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.55);
  }

  .hero-cta {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #ffffff;
    border: 1px solid rgba(255,255,255,0.5);
    padding: 0.3rem 0.9rem;
    transition: background 0.15s, border-color 0.15s;
  }

  .hero-tile:hover .hero-cta {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.8);
  }

  .hero-image-panel {
    position: relative;
    overflow: hidden;
    background: var(--color-surface-2);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-tile:hover .hero-img { transform: scale(1.04); }

  .hero-img-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-tile-surface);
  }

  /* ── STREAM ── */
  .stream-section { padding: 2rem 0 0; }

  .stream-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .stream-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .stream-rule {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  /* ── GRID ── */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  /* post-card styles は global.css で定義済み */

  /* ── INFINITE SCROLL ── */
  .load-sentinel { height: 1px; }

  .load-status {
    display: flex;
    justify-content: center;
    padding: 2rem 0;
  }

  .load-dots {
    display: flex;
    gap: 0.4rem;
  }

  .load-dots span {
    width: 6px;
    height: 6px;
    background: var(--color-blue);
    animation: pulse 1s ease-in-out infinite;
  }

  .load-dots span:nth-child(2) { animation-delay: 0.15s; }
  .load-dots span:nth-child(3) { animation-delay: 0.3s; }

  @keyframes pulse {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 1; }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .post-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .hero-tile { grid-template-columns: 1fr; }
    .hero-image-panel { aspect-ratio: 16 / 9; }
    .post-grid { grid-template-columns: 1fr; }
  }
</style>
