---
import Layout from '../layouts/Layout.astro';

const res = await fetch(
  "http://133.117.77.80:8055/items/posts?fields=*,site.*,eyecatch.filename_disk&filter[status][_eq]=published&sort=-date_created",
  { cache: "no-store" }
);
const json = await res.json();
const posts = Array.isArray(json?.data) ? json.data : [];

function formatDate(dateStr: string | undefined) {
  if (!dateStr) return null;
  return new Date(dateStr).toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title="テストブログYES" description="最新の記事をお届けします。">
  <div class="page">
    <div class="page-header">
      <h1 class="page-title">Articles</h1>
      <span class="page-count">{posts.length}</span>
    </div>

    <div class="posts">
      {posts.map((post, i) => (
        <a href={`/${post.slug}`} class="post" data-index={i}>
          <div class="post-inner">
            <!-- Image -->
            <div class={`post-image-wrap ${i % 2 === 0 ? 'clip-right' : 'clip-left'}`}>
              {post.eyecatch?.filename_disk ? (
                <img
                  src={`https://img.134.network/${post.eyecatch.filename_disk}`}
                  alt={post.title}
                  loading="lazy"
                  class="post-img"
                />
              ) : (
                <div class="post-img-placeholder">No Image</div>
              )}
              <div class="post-img-overlay" />
            </div>

            <!-- Content -->
            <div class="post-content">
              <span class="post-num">{String(i + 1).padStart(2, '0')}</span>
              <h2 class="post-title">{post.title}</h2>
              <div class="post-meta">
                {post.site?.name && <span>{post.site.name}</span>}
                {post.date_created && <span>{formatDate(post.date_created)}</span>}
              </div>
              <span class="post-arrow">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .page {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 2rem 8rem;
  }

  .page-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .page-title {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    font-weight: 400;
  }

  .page-count {
    font-size: 0.7rem;
    color: #FFCC22;
    letter-spacing: 0.1em;
    opacity: 0.7;
  }

  /* Posts list */
  .posts {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post {
    display: block;
    text-decoration: none;
    opacity: 0;
    transform: translateY(32px);
    animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .post[data-index="0"] { animation-delay: 0.05s; }
  .post[data-index="1"] { animation-delay: 0.15s; }
  .post[data-index="2"] { animation-delay: 0.25s; }
  .post[data-index="3"] { animation-delay: 0.35s; }
  .post[data-index="4"] { animation-delay: 0.45s; }
  .post[data-index="5"] { animation-delay: 0.55s; }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .post-inner {
    position: relative;
    padding: 3rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post:last-child .post-inner {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .post:hover .post-inner {
    transform: translateX(6px);
  }

  /* Image */
  .post-image-wrap {
    width: 100%;
    aspect-ratio: 16 / 7;
    overflow: hidden;
    position: relative;
    margin-bottom: 1.75rem;
  }

  /* Alternating diagonal clips */
  .clip-right {
    clip-path: polygon(0 0, 100% 0, 100% 82%, 0 100%);
  }

  .clip-left {
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 82%);
  }

  .post-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.7);
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1),
                filter 0.4s ease;
  }

  .post:hover .post-img {
    transform: scale(1.05);
    filter: brightness(0.9);
  }

  .post-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10, 10, 10, 0.3) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .post-img-placeholder {
    width: 100%;
    height: 100%;
    background: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.1);
  }

  /* Content */
  .post-content {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    align-items: start;
    gap: 0 1.5rem;
  }

  .post-num {
    grid-row: 1 / 3;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    color: #FFCC22;
    opacity: 0.25;
    letter-spacing: -0.02em;
    align-self: center;
    transition: opacity 0.2s;
    font-style: italic;
  }

  .post:hover .post-num {
    opacity: 0.7;
  }

  .post-title {
    grid-column: 2;
    grid-row: 1;
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    font-weight: 700;
    line-height: 1.5;
    color: #ffffff;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .post:hover .post-title {
    color: #FFCC22;
  }

  .post-meta {
    grid-column: 2;
    grid-row: 2;
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.08em;
  }

  .post-arrow {
    grid-column: 3;
    grid-row: 1 / 3;
    font-size: 1.1rem;
    color: #FFCC22;
    opacity: 0;
    align-self: center;
    transform: translateX(-8px);
    transition: opacity 0.25s, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post:hover .post-arrow {
    opacity: 0.8;
    transform: translateX(0);
  }
</style>
