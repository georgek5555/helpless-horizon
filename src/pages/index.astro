---
import Layout from '../layouts/Layout.astro';

const res = await fetch(
  "http://133.117.77.80:8055/items/posts?fields=*,site.*,eyecatch.filename_disk&filter[status][_eq]=published&sort=-date_created",
  { cache: "no-store" }
);
const json = await res.json();
const posts = Array.isArray(json?.data) ? json.data : [];

function formatDate(dateStr: string | undefined) {
  if (!dateStr) return null;
  return new Date(dateStr).toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title="テストブログYES" description="最新の記事をお届けします。">
  <div class="container">
    <div class="heading">
      <h1>記事一覧</h1>
      <span class="count">{posts.length} articles</span>
    </div>

    {posts.length > 0 ? (
      <div class="grid">
        {posts.map((post) => (
          <a href={`/${post.slug}`} class="card">
            <div class="card-image">
              {post.eyecatch?.filename_disk ? (
                <img
                  src={`https://img.134.network/${post.eyecatch.filename_disk}`}
                  alt={post.title}
                  loading="lazy"
                />
              ) : (
                <div class="card-image-placeholder">
                  <span>No Image</span>
                </div>
              )}
            </div>
            <div class="card-body">
              <h2 class="card-title">{post.title}</h2>
              <div class="card-meta">
                {post.site?.name && <span>{post.site.name}</span>}
                {post.date_created && <span>{formatDate(post.date_created)}</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">記事がまだありません。</p>
    )}
  </div>
</Layout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  .heading {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .heading h1 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #ffffff;
  }

  .count {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.1em;
    font-weight: 400;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2px;
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .card {
    display: block;
    text-decoration: none;
    background: #111111;
    overflow: hidden;
    transition: background 0.2s;
  }

  .card:hover {
    background: #1a1a1a;
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #1a1a1a;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
    filter: brightness(0.85);
  }

  .card:hover .card-image img {
    transform: scale(1.04);
    filter: brightness(1);
  }

  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1a1a1a;
  }

  .card-image-placeholder span {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.15);
  }

  .card-body {
    padding: 1.25rem 1.25rem 1.5rem;
  }

  .card-title {
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.6;
    color: #ffffff;
    transition: color 0.15s;
  }

  .card:hover .card-title {
    color: #FFCC22;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.75rem;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.05em;
  }

  .empty {
    text-align: center;
    color: rgba(255, 255, 255, 0.3);
    padding: 6rem 0;
    font-size: 0.9rem;
  }
</style>
