---  
export const prerender = false;

const { slug } = Astro.params;

const res = await fetch("http://133.117.77.80:8055/items/posts?fields=*,site.*&filter[status][_eq]=published");
const json = await res.json();
const posts = Array.isArray(json?.data) ? json.data : [];
const normalizedSlug = String(slug ?? '').trim();
const post = posts.find((item) => String(item?.slug ?? '').trim() === normalizedSlug) ?? null;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post?.title ?? '記事が見つかりません'}</title>
  </head>
  <body>
    {post ? (
      <>
        <h1>{post.title}</h1>

        {post.eyecatch_url && (
          <img
            src={post.eyecatch_url}
            alt={post.title}
            style="width: 100%; max-width: 600px; height: auto;"
          />
        )}

        {post.site?.name && <p>{post.site.name}</p>}

        <div>
          <pre>{post.body}</pre>
        </div>
      </>
    ) : (
      <p>記事が見つかりません。</p>
    )}
  </body>
</html>