---
export async function getStaticPaths() {
  const res = await fetch("http://133.117.77.80:8055/items/posts?fields=slug&filter[status][_eq]=published");
  const json = await res.json();
  const posts = Array.isArray(json?.data) ? json.data : [];

  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;

const res = await fetch("http://133.117.77.80:8055/items/posts?fields=*,site.*&filter[status][_eq]=published", {
  cache: "no-store"
});
const json = await res.json();
const posts = Array.isArray(json?.data) ? json.data : [];
const normalizedSlug = String(slug ?? '').trim();
const post = posts.find((item) => String(item?.slug ?? '').trim() === normalizedSlug) ?? null;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post?.title ?? '記事が見つかりません'}</title>
  </head>
  <body>
    {post ? (
      <>
        <h1>{post.title}</h1>

{post.eyecatch && (
  <img
    src={`http://133.117.77.80:8055/assets/${post.eyecatch}`}
    alt={post.title}
    style="width: 100%; max-width: 600px; height: auto;"
  />
)}

        {post.site?.name && <p>{post.site.name}</p>}

        <div>
          <div set:html={post.body} />
        </div>
      </>
    ) : (
      <p>記事が見つかりません。</p>
    )}
  </body>
</html>