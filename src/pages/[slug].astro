---
import Layout from '../layouts/Layout.astro';
import { getPosts, getPost, getTitle, getExcerpt, getContent, getFeaturedImage, getCategory, getPostPath } from '../lib/wordpress';

export async function getStaticPaths() {
  let posts: any[] = [];
  try {
    posts = await getPosts(100);
  } catch (e) {
    console.error('[getStaticPaths] getPosts failed:', e);
    return [];
  }

  return posts.map((post, i) => ({
    // URLはWPのpermalinkパス (例: "20151102306") を使用
    params: { slug: getPostPath(post) },
    props: {
      wpSlug: post.slug, // API検索用のWPスラグ
      prevPost: posts[i - 1] ? { slug: getPostPath(posts[i - 1]), title: getTitle(posts[i - 1]) } : null,
      nextPost: posts[i + 1] ? { slug: getPostPath(posts[i + 1]), title: getTitle(posts[i + 1]) } : null,
      relatedPosts: posts.filter((_, j) => j !== i).slice(0, 4).map(p => ({
        slug: getPostPath(p),
        title: getTitle(p),
        eyecatch: getFeaturedImage(p),
      })),
    },
  }));
}

const { slug, wpSlug, prevPost, nextPost, relatedPosts = [] } = { ...Astro.params, ...Astro.props };

let post: any = null;
try {
  post = await getPost(wpSlug as string);
} catch {
  post = null;
}

function fixContent(html: string): string {
  // 1) Simplicity2テーマのlazyload: data-originalを実srcに置換
  let out = html.replace(
    /(<img[^>]+)src="[^"]*1x1\.trans\.gif"([^>]*data-original=")([^"]+)"/g,
    '$1src="$3"$2$3"'
  );

  // 2) 外部ブログカード (heartrails サムネ + タイトルリンク + はてなカウンター)
  //    <p><a href="URL"><img class="alignleft"...></a><a ...>title</a><a ...hatena...></a></p>
  //    → <a class="ext-blog-card"> カード形式に変換
  out = out.replace(
    /<p>\s*(?:<a[^>]*href="([^"]+)"[^>]*>\s*(?:<img[^>]*class="[^"]*alignleft[^"]*"[^>]*src="([^"]+)"[^>]*>)(?:<noscript>[\s\S]*?<\/noscript>)?\s*<\/a>)\s*(?:<a[^>]*href="[^"]*"[^>]*>([\s\S]*?)<\/a>)[\s\S]*?<\/p>/g,
    (_match: string, href: string, imgSrc: string, titleHtml: string) => {
      const title = titleHtml.replace(/<[^>]+>/g, '').trim();
      let domain = href;
      try { domain = new URL(href).hostname; } catch {}
      return `<a class="ext-blog-card" href="${href}" target="_blank" rel="noopener noreferrer"><div class="ext-blog-card-img"><img src="${imgSrc}" alt=""></div><div class="ext-blog-card-body"><span class="ext-blog-card-title">${title}</span><span class="ext-blog-card-domain">${domain}</span></div></a>`;
    }
  );

  // 3) YouTube URL → iframe embed
  out = out.replace(
    /<p>\s*(?:<a[^>]*>)?\s*(https?:\/\/(?:www\.)?(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_\-]+)[^\s<]*?)\s*(?:<\/a>)?\s*<\/p>/g,
    (_match: string, _url: string, id: string) =>
      `<div class="video-wrap"><iframe src="https://www.youtube.com/embed/${id}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>`
  );
  return out;
}

const fixedBody = post ? fixContent(getContent(post)) : '';

const ogImage = post ? (getFeaturedImage(post) ?? undefined) : undefined;

const siteUrl = import.meta.env.SITE_URL ?? (Astro.site?.toString().replace(/\/$/, '') ?? 'https://solocial.net');
const canonical = `${siteUrl}/${slug}`;

function formatDate(dateStr: string | undefined) {
  if (!dateStr) return null;
  return new Date(dateStr).toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const categoryName = post ? getCategory(post) : null;
const postTitle = post ? getTitle(post) : '記事が見つかりません';
const postExcerpt = post ? getExcerpt(post) : '';

const jsonLd = post ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  url: canonical,
  ...(ogImage ? { image: ogImage } : {}),
  ...(post.date ? { datePublished: post.date } : {}),
} : null;
---

<Layout
  title={postTitle}
  ogImage={ogImage}
  canonicalUrl={canonical}
  type="article"
  publishedAt={post?.date}
>
  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  {post ? (
    <article class="article">

      <!-- Header -->
      <header class="article-header">
        <div class="article-wrap">
          <div class="article-meta">
            {categoryName && <span class="article-category">{categoryName.toUpperCase()}</span>}
            {post.date && <span class="article-date">{formatDate(post.date)}</span>}
          </div>
          <h1 class="article-title">{postTitle}</h1>
        </div>
      </header>

      <!-- SNS Share (top) -->
      <div class="share-bar share-bar--top">
        <div class="article-wrap">
          <span class="share-label">SHARE</span>
          <div class="share-buttons">
            <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(canonical)}&text=${encodeURIComponent(post.title)}`} target="_blank" rel="noopener" class="share-btn share-btn--x">X / Twitter</a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonical)}`} target="_blank" rel="noopener" class="share-btn share-btn--fb">Facebook</a>
            <a href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(canonical)}`} target="_blank" rel="noopener" class="share-btn share-btn--line">LINE</a>
          </div>
        </div>
      </div>

      <!-- Body -->
      <div class="article-body">
        <div class="article-wrap">
          <div class="prose" set:html={fixedBody} />
        </div>
      </div>

      <!-- SNS Share (bottom) -->
      <div class="share-bar share-bar--bottom">
        <div class="article-wrap">
          <span class="share-label">この記事をシェア</span>
          <div class="share-buttons">
            <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(canonical)}&text=${encodeURIComponent(post.title)}`} target="_blank" rel="noopener" class="share-btn share-btn--x">X / Twitter</a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonical)}`} target="_blank" rel="noopener" class="share-btn share-btn--fb">Facebook</a>
            <a href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(canonical)}`} target="_blank" rel="noopener" class="share-btn share-btn--line">LINE</a>
          </div>
        </div>
      </div>

      <!-- Related Articles -->
      {relatedPosts.length > 0 && (
        <div class="related-section">
          <div class="article-wrap">
            <div class="related-header">
              <span class="related-label">RELATED ARTICLES</span>
              <div class="related-rule"></div>
            </div>
            <div class="related-grid">
              {relatedPosts.map((rp: any) => (
                <a href={`/${rp.slug}`} class="related-card">
                  <div class="related-img-wrap">
                    {rp.eyecatch ? (
                      <img src={rp.eyecatch} alt={rp.title} loading="lazy" class="related-img" />
                    ) : (
                      <div class="related-img-empty"></div>
                    )}
                  </div>
                  <p class="related-title">{rp.title}</p>
                </a>
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- Navigation -->
      <nav class="post-nav">
        <div class="article-wrap post-nav-inner">
          {prevPost ? (
            <a href={`/${prevPost.slug}`} class="post-nav-item post-nav-prev">
              <span class="post-nav-label">← PREV</span>
              <span class="post-nav-title">{prevPost.title}</span>
            </a>
          ) : <div />}
          {nextPost ? (
            <a href={`/${nextPost.slug}`} class="post-nav-item post-nav-next">
              <span class="post-nav-label">NEXT →</span>
              <span class="post-nav-title">{nextPost.title}</span>
            </a>
          ) : <div />}
        </div>
      </nav>

    </article>
  ) : (
    <div class="not-found">
      <div class="article-wrap">
        <p>記事が見つかりません。</p>
        <a href="/">← 一覧へ戻る</a>
      </div>
    </div>
  )}
</Layout>

<style>
  /* ── Layout ── */
  .article {
    padding-bottom: 6rem;
    animation: fadeUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .article-wrap {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ── */
  .article-header {
    background: var(--color-tile-blue);
    padding: 2.5rem 0 2.75rem;
    margin-bottom: 0;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .article-category {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.65);
    background: rgba(255,255,255,0.12);
    padding: 0.25rem 0.7rem;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(255,255,255,0.2);
  }

  .article-date {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.5);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.75rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: #ffffff;
    margin-bottom: 1rem;
  }

  .article-deck {
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.72);
    max-width: 560px;
  }

  /* ── Body ── */
  .article-body {
    padding-top: 2.5rem;
  }

  .prose {
    font-size: 1rem;
    line-height: 1.9;
    color: var(--color-text);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.0;
    color: var(--color-text);
    margin-top: 3rem;
    margin-bottom: 1rem;
    border-left: 4px solid var(--color-blue);
    padding-left: 0.85rem;
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-blue);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(h4) {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: var(--font-mono);
    color: var(--color-text-secondary);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1.6rem;
  }

  .prose :global(img) {
    width: 100%;
    height: auto;
    margin: 2rem 0;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    display: block;
  }

  .prose :global(.video-wrap) {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    margin: 2rem 0;
    background: var(--color-surface-2);
    border-radius: var(--radius-lg);
  }
  .prose :global(.video-wrap iframe) {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }

  .prose :global(a) {
    color: var(--color-blue);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-blue-mid);
  }
  .prose :global(a:hover) {
    text-decoration-color: var(--color-blue);
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 0;
    margin-bottom: 1.6rem;
    list-style: none;
  }
  .prose :global(ul li) {
    position: relative;
    padding-left: 1.2rem;
    margin-bottom: 0.45rem;
    line-height: 1.8;
  }
  .prose :global(ul li)::before {
    content: '';
    position: absolute;
    left: 0; top: 0.65em;
    width: 5px; height: 5px;
    background: var(--color-blue);
    border-radius: 50%;
  }
  .prose :global(ol) { counter-reset: ol-counter; }
  .prose :global(ol li) {
    position: relative;
    padding-left: 2rem;
    margin-bottom: 0.45rem;
    counter-increment: ol-counter;
    line-height: 1.8;
  }
  .prose :global(ol li)::before {
    content: counter(ol-counter);
    position: absolute;
    left: 0; top: 0.1em;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-blue);
    background: var(--color-blue-light);
    width: 1.4rem; height: 1.4rem;
    display: flex;
    align-items: center; justify-content: center;
    border-radius: var(--radius-xs);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-blue);
    background: var(--color-blue-light);
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--color-blue);
    background: var(--color-blue-light);
    border: 1px solid var(--color-blue-mid);
    border-radius: var(--radius-xs);
    padding: 0.1em 0.4em;
  }

  .prose :global(pre) {
    background: #0f1117;
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
  }
  .prose :global(pre code) {
    background: transparent;
    border: none; padding: 0;
    color: #e2e8f0;
    font-size: 0.875rem;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }

  /* ── External blog card (heartrails pattern) ── */
  .prose :global(.ext-blog-card) {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    text-decoration: none !important;
    margin: 1.5rem 0;
    overflow: hidden;
    transition: box-shadow 0.2s;
  }

  .prose :global(.ext-blog-card:hover) {
    box-shadow: 0 0 0 2px var(--color-blue);
  }

  .prose :global(.ext-blog-card-img) {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    background: var(--color-surface-2);
    overflow: hidden;
  }

  .prose :global(.ext-blog-card-img img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    margin: 0 !important;
    border: none !important;
    border-radius: 0 !important;
    display: block;
  }

  .prose :global(.ext-blog-card-body) {
    flex: 1;
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .prose :global(.ext-blog-card-title) {
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .prose :global(.ext-blog-card:hover .ext-blog-card-title) {
    color: var(--color-blue);
  }

  .prose :global(.ext-blog-card-domain) {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-blue);
  }

  /* ── Blog card (WordPress internal link card) ── */
  .prose :global(.hover-blog-card) {
    display: block;
    text-decoration: none !important;
    margin: 2rem 0;
  }

  .prose :global(.blog-card) {
    display: flex;
    gap: 0;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    overflow: hidden;
    transition: box-shadow 0.2s;
  }

  .prose :global(.hover-blog-card:hover .blog-card) {
    box-shadow: 0 0 0 2px var(--color-blue);
  }

  .prose :global(.blog-card-thumbnail) {
    flex-shrink: 0;
    width: 120px;
    background: var(--color-surface-2);
    overflow: hidden;
  }

  .prose :global(.blog-card-thumbnail img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    margin: 0 !important;
    border: none !important;
    border-radius: 0 !important;
    display: block;
  }

  .prose :global(.blog-card-content) {
    flex: 1;
    padding: 0.85rem 1rem;
    min-width: 0;
  }

  .prose :global(.blog-card-title) {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 0.4rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .prose :global(.hover-blog-card:hover .blog-card-title) {
    color: var(--color-blue);
  }

  .prose :global(.blog-card-excerpt) {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .prose :global(.blog-card-footer) {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding: 0.5rem 1rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    flex-shrink: 0;
    align-self: stretch;
    flex-direction: column;
    justify-content: center;
  }

  .prose :global(.blog-card-site),
  .prose :global(.blog-card-date) {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .prose :global(.blog-card-site) {
    color: var(--color-blue);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
  }
  .prose :global(th) {
    background: var(--color-blue-light);
    border: 1px solid var(--color-border);
    padding: 0.6rem 1rem;
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-blue-dark);
  }
  .prose :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.6rem 1rem;
  }

  /* ── SNS Share ── */
  .share-bar {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .share-bar--top {
    margin-bottom: 2.5rem;
  }

  .share-bar--bottom {
    margin-top: 3rem;
    margin-bottom: 0;
  }

  .share-bar .article-wrap {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
  }

  .share-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .share-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .share-btn {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.4rem 0.9rem;
    border: 1px solid;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    display: inline-block;
  }

  .share-btn--x {
    color: #0f1117;
    border-color: #0f1117;
  }
  .share-btn--x:hover {
    background: #0f1117;
    color: #fff;
  }

  .share-btn--fb {
    color: #1877f2;
    border-color: #1877f2;
  }
  .share-btn--fb:hover {
    background: #1877f2;
    color: #fff;
  }

  .share-btn--line {
    color: #06c755;
    border-color: #06c755;
  }
  .share-btn--line:hover {
    background: #06c755;
    color: #fff;
  }

  /* ── Related Articles ── */
  .related-section {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
    margin-top: 3rem;
  }

  .related-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .related-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .related-rule {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    border: 1px solid var(--color-border);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: var(--color-bg);
    transition: background 0.15s;
    border-right: 1px solid var(--color-border);
  }

  .related-card:last-child {
    border-right: none;
  }

  .related-card:hover {
    background: var(--color-surface);
  }

  .related-img-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface-2);
  }

  .related-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
