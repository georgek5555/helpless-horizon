---
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const res = await fetch("http://133.117.77.80:8055/items/posts?fields=slug&filter[status][_eq]=published");
  const json = await res.json();
  const posts = Array.isArray(json?.data) ? json.data : [];

  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;

const res = await fetch(`http://133.117.77.80:8055/items/posts?fields=*,site.*,eyecatch.filename_disk&filter[slug][_eq]=${slug}&filter[status][_eq]=published`);
const json = await res.json();
const post = json?.data?.[0] ?? null;

const fixedBody = post?.body?.replace(
  /http:\/\/133\.117\.77\.80:8055\/assets\//g,
  'https://img.134.network/'
) ?? '';

const ogImage = post?.eyecatch?.filename_disk
  ? `https://img.134.network/${post.eyecatch.filename_disk}`
  : undefined;

const siteUrl = import.meta.env.SITE_URL ?? (Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.134.network');
const canonical = `${siteUrl}/${slug}`;

function formatDate(dateStr: string | undefined) {
  if (!dateStr) return null;
  return new Date(dateStr).toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const jsonLd = post ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  url: canonical,
  ...(ogImage ? { image: ogImage } : {}),
  ...(post.date_created ? { datePublished: post.date_created } : {}),
  ...(post.date_updated ? { dateModified: post.date_updated } : {}),
} : null;
---

<Layout
  title={post?.title ?? '記事が見つかりません'}
  ogImage={ogImage}
  canonicalUrl={canonical}
  type="article"
  publishedAt={post?.date_created}
>
  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  {post ? (
    <article class="article">
      <header class="article-header">
        <div class="article-meta-top">
          {post.site?.name && <span class="article-site">{post.site.name}</span>}
          {post.date_created && <span class="article-date">{formatDate(post.date_created)}</span>}
        </div>
        <h1 class="article-title">{post.title}</h1>
      </header>

      <div class="article-body prose" set:html={fixedBody} />

      <div class="article-back">
        <a href="/">← 記事一覧に戻る</a>
      </div>
    </article>
  ) : (
    <div class="not-found">
      <p>記事が見つかりません。</p>
      <a href="/">← 記事一覧に戻る</a>
    </div>
  )}
</Layout>

<style>
  .article {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .article-meta-top {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1.25rem;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.35);
  }

  .article-site {
    color: #FFCC22;
    opacity: 0.8;
  }

  .article-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: 0.03em;
    color: #ffffff;
  }

  .article-date {
    /* inherited from meta-top */
  }

  /* Article body prose styles */
  .prose {
    font-size: 1rem;
    line-height: 2;
    color: #ffffff;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: 0.03em;
    color: #ffffff;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose :global(h2) {
    font-size: 1.3rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .prose :global(h3) { font-size: 1.1rem; }
  .prose :global(h4) { font-size: 1rem; color: rgba(255,255,255,0.8); }

  .prose :global(p) {
    margin-bottom: 1.5rem;
    color: #ffffff;
  }

  .prose :global(img) {
    width: 100%;
    height: auto;
    margin: 2rem 0;
    display: block;
  }

  .prose :global(a) {
    color: #FFCC22;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) {
    opacity: 0.75;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .prose :global(ul) { list-style-type: disc; }
  .prose :global(ol) { list-style-type: decimal; }
  .prose :global(li) {
    margin-bottom: 0.4rem;
    color: #ffffff;
  }

  .prose :global(blockquote) {
    border-left: 3px solid #FFCC22;
    padding: 0.75rem 1.5rem;
    margin: 2rem 0;
    color: rgba(255, 255, 255, 0.6);
    font-style: italic;
  }

  .prose :global(code) {
    background: rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    padding: 0.1em 0.4em;
    font-size: 0.875em;
    font-family: ui-monospace, monospace;
    color: #FFCC22;
  }

  .prose :global(pre) {
    background: #111111;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
  }
  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    color: #ffffff;
    font-size: 0.875rem;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin: 3rem 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
  }
  .prose :global(th) {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.6rem 1rem;
    text-align: left;
    font-weight: 600;
    color: #ffffff;
  }
  .prose :global(td) {
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.6rem 1rem;
    color: #ffffff;
  }

  .article-back {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .article-back a {
    font-size: 0.85rem;
    color: #FFCC22;
    text-decoration: none;
    letter-spacing: 0.05em;
    opacity: 0.7;
    transition: opacity 0.15s;
  }
  .article-back a:hover {
    opacity: 1;
  }

  .not-found {
    max-width: 720px;
    margin: 0 auto;
    padding: 8rem 2rem;
    text-align: center;
  }
  .not-found p {
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 1.5rem;
  }
  .not-found a {
    color: #FFCC22;
    font-size: 0.85rem;
    text-decoration: none;
    opacity: 0.7;
  }
  .not-found a:hover {
    opacity: 1;
  }
</style>
