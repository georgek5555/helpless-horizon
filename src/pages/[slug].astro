---
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const res = await fetch("http://133.117.77.80:8055/items/posts?fields=slug&filter[status][_eq]=published");
  const json = await res.json();
  const posts = Array.isArray(json?.data) ? json.data : [];

  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;

const res = await fetch(`http://133.117.77.80:8055/items/posts?fields=*,site.*,eyecatch.filename_disk&filter[slug][_eq]=${slug}&filter[status][_eq]=published`);
const json = await res.json();
const post = json?.data?.[0] ?? null;

const fixedBody = post?.body?.replace(
  /http:\/\/133\.117\.77\.80:8055\/assets\//g,
  'https://img.134.network/'
) ?? '';

const ogImage = post?.eyecatch?.filename_disk
  ? `https://img.134.network/${post.eyecatch.filename_disk}`
  : undefined;

const siteUrl = import.meta.env.SITE_URL ?? (Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.134.network');
const canonical = `${siteUrl}/${slug}`;

function formatDate(dateStr: string | undefined) {
  if (!dateStr) return null;
  return new Date(dateStr).toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const jsonLd = post ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  url: canonical,
  ...(ogImage ? { image: ogImage } : {}),
  ...(post.date_created ? { datePublished: post.date_created } : {}),
  ...(post.date_updated ? { dateModified: post.date_updated } : {}),
} : null;
---

<Layout
  title={post?.title ?? '記事が見つかりません'}
  ogImage={ogImage}
  canonicalUrl={canonical}
  type="article"
  publishedAt={post?.date_created}
>
  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  {post ? (
    <article class="article">

      <!-- Header -->
      <header class="article-header">
        <div class="article-header-inner">
          {post.date_created && (
            <p class="article-date">{formatDate(post.date_created)}</p>
          )}
          <h1 class="article-title">{post.title}</h1>
        </div>
        <div class="article-header-line" />
      </header>

      <!-- Body -->
      <div class="article-body">
        <div class="prose" set:html={fixedBody} />
      </div>

      <!-- Back -->
      <div class="article-back">
        <a href="/">← Articles</a>
      </div>

    </article>
  ) : (
    <div class="not-found">
      <p>記事が見つかりません。</p>
      <a href="/">← Articles</a>
    </div>
  )}
</Layout>

<style>
  .article {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem 8rem;
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Header */
  .article-header {
    padding-top: 3.5rem;
    margin-bottom: 4rem;
    position: relative;
  }

  .article-header-inner {
    padding-bottom: 2.5rem;
  }

  .article-date {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 1.25rem;
  }

  .article-title {
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: 0.02em;
    color: #ffffff;
  }

  /* Diagonal decorative line under title */
  .article-header-line {
    position: relative;
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    transform-origin: left center;
  }

  .article-header-line::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 3rem;
    height: 2px;
    background: #FFCC22;
    transform: skewX(-20deg);
    transform-origin: left center;
  }

  /* Body */
  .article-body {
    position: relative;
  }

  .prose {
    font-size: 1rem;
    line-height: 2.1;
    color: #ffffff;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: 0.03em;
    color: #ffffff;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  .prose :global(h2) {
    font-size: 1.3rem;
    position: relative;
    padding-left: 1rem;
  }
  .prose :global(h2)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.2em;
    bottom: 0.2em;
    width: 2px;
    background: #FFCC22;
    transform: skewY(-8deg);
  }
  .prose :global(h3) { font-size: 1.1rem; }
  .prose :global(h4) { font-size: 1rem; color: rgba(255,255,255,0.7); }

  .prose :global(p) {
    margin-bottom: 1.75rem;
    color: #ffffff;
  }

  .prose :global(img) {
    width: 100%;
    height: auto;
    margin: 2.5rem 0;
    display: block;
    clip-path: polygon(0 0, 100% 0, 100% 94%, 97% 100%, 0 100%);
  }

  .prose :global(a) {
    color: #FFCC22;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) { opacity: 0.75; }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.75rem;
  }
  .prose :global(ul) { list-style-type: disc; }
  .prose :global(ol) { list-style-type: decimal; }
  .prose :global(li) {
    margin-bottom: 0.4rem;
    color: #ffffff;
  }

  .prose :global(blockquote) {
    border-left: 3px solid #FFCC22;
    padding: 0.75rem 1.5rem;
    margin: 2.5rem 0;
    color: rgba(255, 255, 255, 0.55);
    font-style: italic;
    transform: skewX(-1deg);
  }

  .prose :global(code) {
    background: rgba(255, 204, 34, 0.08);
    border-radius: 2px;
    padding: 0.1em 0.4em;
    font-size: 0.875em;
    font-family: ui-monospace, monospace;
    color: #FFCC22;
  }

  .prose :global(pre) {
    background: #0f0f0f;
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
  }
  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    color: #ffffff;
    font-size: 0.875rem;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin: 3rem 0;
    transform: skewX(-2deg);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
  }
  .prose :global(th) {
    background: rgba(255, 204, 34, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.6rem 1rem;
    text-align: left;
    font-weight: 600;
  }
  .prose :global(td) {
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.6rem 1rem;
  }

  /* Back link */
  .article-back {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .article-back a {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.3);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .article-back a:hover {
    color: #FFCC22;
  }

  /* Not found */
  .not-found {
    max-width: 760px;
    margin: 0 auto;
    padding: 8rem 2rem;
    text-align: center;
  }
  .not-found p {
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 1.5rem;
  }
  .not-found a {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.3);
    text-decoration: none;
    text-transform: uppercase;
  }
  .not-found a:hover { color: #FFCC22; }
</style>
