---
export async function getStaticPaths() {
  const res = await fetch("http://133.117.77.80:8055/items/posts?fields=slug&filter[status][_eq]=published");
  const json = await res.json();
  const posts = Array.isArray(json?.data) ? json.data : [];

  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;

const res = await fetch(`http://133.117.77.80:8055/items/posts?fields=*,site.*,eyecatch.filename_disk&filter[slug][_eq]=${slug}&filter[status][_eq]=published`);
const json = await res.json();
const post = json?.data?.[0] ?? null;

const fixedBody = post?.body?.replace(
  /http:\/\/133\.117\.77\.80:8055\/assets\//g,
  'https://img.134.network/'
) ?? '';
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post?.title ?? '記事が見つかりません'}</title>
  </head>
  <body>
    {post ? (
      <>
        <h1>{post.title}</h1>

        {post.eyecatch?.filename_disk && (
          <img
            src={`https://img.134.network/${post.eyecatch.filename_disk}`}
            alt={post.title}
            style="width: 100%; max-width: 600px; height: auto;"
          />
        )}

        {post.site?.name && <p>{post.site.name}</p>}

        <div set:html={fixedBody} />
      </>
    ) : (
      <p>記事が見つかりません。</p>
    )}
  </body>
</html>