---
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const res = await fetch("http://133.117.77.80:8055/items/posts?fields=slug,title&filter[status][_eq]=published&sort=-date_created");
  const json = await res.json();
  const posts = Array.isArray(json?.data) ? json.data : [];

  return posts.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      prevPost: posts[i - 1] ? { slug: posts[i - 1].slug, title: posts[i - 1].title } : null,
      nextPost: posts[i + 1] ? { slug: posts[i + 1].slug, title: posts[i + 1].title } : null,
    },
  }));
}

const { slug, prevPost, nextPost } = { ...Astro.params, ...Astro.props };

const res = await fetch(`http://133.117.77.80:8055/items/posts?fields=*,site.*,eyecatch.filename_disk&filter[slug][_eq]=${slug}&filter[status][_eq]=published`);
const json = await res.json();
const post = json?.data?.[0] ?? null;

function embedYouTube(html: string): string {
  // YouTubeのURLを<p>タグ内で検出してiframeに変換
  return html.replace(
    /<p>\s*(?:<a[^>]*>)?\s*(https?:\/\/(?:www\.)?(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_\-]+)[^\s<]*?)\s*(?:<\/a>)?\s*<\/p>/g,
    (_match: string, _url: string, id: string) =>
      `<div class="video-wrap"><iframe src="https://www.youtube.com/embed/${id}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>`
  );
}

const fixedBody = embedYouTube(
  post?.body?.replace(
    /http:\/\/133\.117\.77\.80:8055\/assets\//g,
    'https://img.134.network/'
  ) ?? ''
);

const ogImage = post?.eyecatch?.filename_disk
  ? `https://img.134.network/${post.eyecatch.filename_disk}`
  : undefined;

const siteUrl = import.meta.env.SITE_URL ?? (Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.134.network');
const canonical = `${siteUrl}/${slug}`;

function formatDate(dateStr: string | undefined) {
  if (!dateStr) return null;
  return new Date(dateStr).toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const jsonLd = post ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  url: canonical,
  ...(ogImage ? { image: ogImage } : {}),
  ...(post.date_created ? { datePublished: post.date_created } : {}),
  ...(post.date_updated ? { dateModified: post.date_updated } : {}),
} : null;
---

<Layout
  title={post?.title ?? '記事が見つかりません'}
  ogImage={ogImage}
  canonicalUrl={canonical}
  type="article"
  publishedAt={post?.date_created}
>
  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  {post ? (
    <article class="article">

      <!-- Header -->
      <header class="article-header">
        <div class="article-header-inner">
          {post.date_created && (
            <p class="article-date">{formatDate(post.date_created)}</p>
          )}
          <h1 class="article-title">{post.title}</h1>
        </div>
      </header>

      <!-- Body -->
      <div class="article-body">
        <div class="prose" set:html={fixedBody} />
      </div>

      <!-- Navigation -->
      <nav class="post-nav">
        {prevPost ? (
          <a href={`/${prevPost.slug}`} class="post-nav-item post-nav-prev">
            <span class="post-nav-label">
              <span class="post-nav-arrow">←</span>
              Prev
            </span>
            <span class="post-nav-title">{prevPost.title}</span>
          </a>
        ) : (
          <div class="post-nav-empty" />
        )}
        <div class="post-nav-divider" />
        {nextPost ? (
          <a href={`/${nextPost.slug}`} class="post-nav-item post-nav-next">
            <span class="post-nav-label">
              Next
              <span class="post-nav-arrow">→</span>
            </span>
            <span class="post-nav-title">{nextPost.title}</span>
          </a>
        ) : (
          <div class="post-nav-empty" />
        )}
      </nav>

    </article>
  ) : (
    <div class="not-found">
      <p>記事が見つかりません。</p>
      <a href="/">← Articles</a>
    </div>
  )}
</Layout>

<style>
  .article {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem 8rem;
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Header */
  .article-header {
    padding-top: 5.5rem;
    margin-bottom: 2rem;
    position: relative;
  }

  .article-header-inner {
    padding-bottom: 0.5rem;
  }

  .article-date {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #FFCC22;
    opacity: 0.7;
    margin-bottom: 1.75rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .article-date::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: #FFCC22;
    opacity: 0.5;
    transform: skewX(-20deg);
  }

  .article-title {
    font-size: clamp(2rem, 5.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0.02em;
    color: #ffffff;
    position: relative;
    padding-left: 1.25rem;
  }

  .article-title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.15em;
    bottom: 0.15em;
    width: 3px;
    background: #FFCC22;
    transform: skewY(-6deg);
  }


  /* Body */
  .article-body {
    position: relative;
  }

  .prose {
    font-size: 1rem;
    line-height: 2.1;
    color: #ffffff;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: 0.03em;
    color: #ffffff;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  .prose :global(h2) {
    font-size: 1.3rem;
    position: relative;
    padding-left: 1rem;
  }
  .prose :global(h2)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.2em;
    bottom: 0.2em;
    width: 2px;
    background: #FFCC22;
    transform: skewY(-8deg);
  }
  .prose :global(h3) {
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .prose :global(h3)::before {
    content: '/';
    color: #FFCC22;
    font-weight: 700;
    font-style: italic;
    font-size: 1.15em;
    flex-shrink: 0;
    line-height: 1;
  }
  .prose :global(h4) { font-size: 1rem; color: rgba(255,255,255,0.7); }

  .prose :global(p) {
    margin-bottom: 1.75rem;
    color: #ffffff;
  }

  .prose :global(img) {
    width: 100%;
    height: auto;
    margin: 2.5rem 0;
    display: block;
  }

  .prose :global(.video-wrap) {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    margin: 2.5rem 0;
    background: #111;
  }
  .prose :global(.video-wrap iframe) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .prose :global(a) {
    color: #FFCC22;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) { opacity: 0.75; }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 0;
    margin-bottom: 1.75rem;
    list-style: none;
  }
  .prose :global(ul li) {
    position: relative;
    padding-left: 1.1rem;
    margin-bottom: 0.6rem;
    color: #ffffff;
  }
  .prose :global(ul li)::before {
    content: '—';
    position: absolute;
    left: 0;
    color: rgba(255, 204, 34, 0.6);
    font-size: 0.75em;
    top: 0.2em;
  }
  .prose :global(ol) {
    counter-reset: ol-counter;
  }
  .prose :global(ol li) {
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: 0.6rem;
    color: #ffffff;
    counter-increment: ol-counter;
  }
  .prose :global(ol li)::before {
    content: counter(ol-counter);
    position: absolute;
    left: 0;
    color: #FFCC22;
    font-size: 0.85rem;
    font-weight: 700;
    top: 0.15em;
  }

  .prose :global(blockquote) {
    border-left: 3px solid #FFCC22;
    padding: 0.75rem 1.5rem;
    margin: 2.5rem 0;
    color: rgba(255, 255, 255, 0.55);
    font-style: italic;
    transform: skewX(-1deg);
  }

  .prose :global(code) {
    background: rgba(255, 204, 34, 0.08);
    border-radius: 2px;
    padding: 0.1em 0.4em;
    font-size: 0.875em;
    font-family: ui-monospace, monospace;
    color: #FFCC22;
  }

  .prose :global(pre) {
    background: #0f0f0f;
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
  }
  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    color: #ffffff;
    font-size: 0.875rem;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin: 3rem 0;
    transform: skewX(-2deg);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
  }
  .prose :global(th) {
    background: rgba(255, 204, 34, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.6rem 1rem;
    text-align: left;
    font-weight: 600;
  }
  .prose :global(td) {
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.6rem 1rem;
  }

  /* Post Navigation */
  .post-nav {
    margin-top: 6rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    position: relative;
  }

.post-nav-divider {
    width: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin: 3rem 0;
    position: relative;
  }

  .post-nav-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: -1px;
    width: 3px;
    height: 1.5rem;
    background: #FFCC22;
    transform: translateY(-50%) skewY(-15deg);
    opacity: 0.4;
  }

  .post-nav-empty {
    display: block;
  }

  .post-nav-item {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 3rem 0;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .post-nav-prev {
    padding-right: 2.5rem;
  }

  .post-nav-next {
    padding-left: 2.5rem;
    align-items: flex-end;
    text-align: right;
  }

  .post-nav-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #FFCC22;
    opacity: 0.55;
    transition: opacity 0.25s;
  }

  .post-nav-next .post-nav-label {
    justify-content: flex-end;
  }

  .post-nav-arrow {
    display: inline-block;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post-nav-prev:hover .post-nav-arrow {
    transform: translateX(-6px);
  }

  .post-nav-next:hover .post-nav-arrow {
    transform: translateX(6px);
  }

  .post-nav-item:hover .post-nav-label {
    opacity: 1;
  }

  .post-nav-title {
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    font-weight: 500;
    line-height: 1.55;
    color: #ffffff;
    transition: color 0.25s;
    position: relative;
    display: inline-block;
  }

  .post-nav-title::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: #FFCC22;
    transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post-nav-next .post-nav-title::after {
    left: auto;
    right: 0;
  }

  .post-nav-item:hover .post-nav-title::after {
    width: 100%;
  }

  .post-nav-item:hover .post-nav-title {
    color: rgba(255, 255, 255, 0.75);
  }

  /* Not found */
  .not-found {
    max-width: 760px;
    margin: 0 auto;
    padding: 8rem 2rem;
    text-align: center;
  }
  .not-found p {
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 1.5rem;
  }
  .not-found a {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.3);
    text-decoration: none;
    text-transform: uppercase;
  }
  .not-found a:hover { color: #FFCC22; }
</style>
